#ifndef SPRINTF__
const byte SPRINTF__=0x01;

include "format.znc"

struct sprintf_ctx {
  char* pos;
};

void _sprintf_sink(char ch, void* ctx) {
  sprintf_ctx* c = ctx;
  *c.pos++ = ch;
}

void sprintf(char* dst, char *fmt, ...) {
  va_list args;
  sprintf_ctx ctx;
  ctx.pos = dst;
  va_start(args, fmt);
  vsprintf(_sprintf_sink, &ctx, fmt, args);
  va_end(args);
  *ctx.pos = 0;
}
#endif