make dot "rubik.dot";

include "io.znc";

int[6*4*4] c;
int s;
int ck;
int[6] co;
char* p;

void cls() {
  char *x;
  for(x=16384;x<22528;x++) {
    *x=255;
  } 
  for(x=22528;x<23296;x++) {
    *x=0;
  } 
  ink(7);
  paper(0);
}

void cset(int i, int j,int k,int n) {
  c[i*16+j*4+k]=n;
}

int cget(int i,int j,int k) {
  return c[i*16+j*4+k];
}

void init() {
  int i;
  int j;
  int k;
  co[0]=7;
  co[1]=2;
  co[2]=6;
  co[3]=3;
  co[4]=4;
  co[5]=1;
  for(i=0;i<6;i++){
    for(j=0;j<4;j++){
      for(k=0;k<4;k++){
        cset(i,j,k,i);
      }
    }
  }
}

void disp() {
  int i;
  int j;
  int k;
  int x;
  int y;
  int idx;
  int col;
  for(i=0;i<6;i++){
    if(i==0) {x=4;y=0;}//top
    else if(i==1) {x=4;y=4;}//front
    else if(i==2) {x=4;y=8;}//bottom
    else if(i==3) {x=4;y=12;}//after
    else if(i==4) {x=0;y=4;}//left
    else if(i==5) {x=8;y=4;}//right
    for(j=0;j<4;j++){
      for(k=0;k<4;k++){
        idx=cget(i,j,k);
        col=co[idx];
        p=22560+x+j+((y+k)<<5);
        *p=col;  
      }
    }
  }
}

int check() {
  int i;
  int j;
  int k;
  int c;
  for(i=0;i<6;i++){
    for(j=0;j<3;j++){
      for(k=0;k<3;k++){
        c=cget(i,j,k);
        if(c!=cget(i,j+1,k))
          return 0;
        if(c!=cget(i,j,k+1))
          return 0;
        if(c!=cget(i,j+1,k+1))
          return 0; 
      }
    }
  }
  return 1;
}

void l(int n) {
  int z;
  z=cget(n,0,0);
  cset(n,0,0,cget(n,3,0));
  cset(n,3,0,cget(n,3,3));
  cset(n,3,3,cget(n,0,3));
  cset(n,0,3,z);

  z=cget(n,1,0);
  cset(n,1,0,cget(n,3,1));
  cset(n,3,1,cget(n,2,3));
  cset(n,2,3,cget(n,0,2));
  cset(n,0,2,z);
  
  z=cget(n,2,0);
  cset(n,2,0,cget(n,3,2));
  cset(n,3,2,cget(n,1,3));
  cset(n,1,3,cget(n,0,1));
  cset(n,0,1,z);

  z=cget(n,1,1);
  cset(n,1,1,cget(n,2,1));
  cset(n,2,1,cget(n,2,2));
  cset(n,2,2,cget(n,1,2));
  cset(n,1,2,z);  
}

void r(int n) {
  int z;
  z=cget(n,0,0);
  cset(n,0,0,cget(n,0,3));
  cset(n,0,3,cget(n,3,3));
  cset(n,3,3,cget(n,3,0));
  cset(n,3,0,z);

  z=cget(n,1,0);
  cset(n,1,0,cget(n,0,2));
  cset(n,0,2,cget(n,2,3));
  cset(n,2,3,cget(n,3,1));
  cset(n,3,1,z);
  
  z=cget(n,2,0);
  cset(n,2,0,cget(n,0,1));
  cset(n,0,1,cget(n,1,3));
  cset(n,1,3,cget(n,3,2));
  cset(n,3,2,z);

  z=cget(n,1,1);
  cset(n,1,1,cget(n,1,2));
  cset(n,1,2,cget(n,2,2));
  cset(n,2,2,cget(n,2,1));
  cset(n,2,1,z);  
}

void ru(int n) {
  int i;
  int z;
  for(i=0;i<4;i++) {
    z=cget(1,n,i);
    cset(1,n,i,cget(2,n,i));
    cset(2,n,i,cget(3,n,i));
    cset(3,n,i,cget(0,n,i));
    cset(0,n,i,z);    
  }
  if(n==0) l(4);
  if(n==3) r(5);
}

void rd(int n) {
  int i;
  int z;
  for(i=0;i<4;i++) {
    z=cget(1,n,i);
    cset(1,n,i,cget(0,n,i));
    cset(0,n,i,cget(3,n,i));
    cset(3,n,i,cget(2,n,i));
    cset(2,n,i,z);    
  }
  if(n==0) r(4);
  if(n==3) l(5);
}

void rr(int n) {
  int i;
  int z;
  for(i=0;i<4;i++) {
    z=cget(1,i,n);
    cset(1,i,n,cget(5,i,n));
    cset(5,i,n,cget(3,3-i,3-n));
    cset(3,3-i,3-n,cget(4,i,n));
    cset(4,i,n,z);    
  }
  if(n==0) r(0);
  if(n==3) l(2);
}

void rl(int n) {
  int i;
  int z;
  for(i=0;i<4;i++) {
    z=cget(1,i,n);
    cset(1,i,n,cget(4,i,n));
    cset(4,i,n,cget(3,3-i,3-n));
    cset(3,3-i,3-n,cget(5,i,n));
    cset(5,i,n,z);    
  }
  if(n==0) l(0);
  if(n==3) r(2);
}

cls();
init();
s=0;
ck=-1;

for(;;) { 
  ru(3);
  ru(2);ru(3);
  ru(1);ru(2);ru(3);

  rl(0);
  rl(1);
  rl(2);
  rl(3);
  
  s++;

  if((s % 13)==0) {
    disp();
    gotoxy(0,19);
    printnum(s);
  }

  if((in(0x7ffe) & 0x01)==0) break;
    
  if(check()== 1) {
    if(ck!=1) {
      disp();
      gotoxy(0,19);
      printnum(s);

      gotoxy(0,18);
      puts("Solved    ");
      ck=1;
    }
    break;
  } else {
    if(ck!=0) {
      gotoxy(0,18);
      puts("Not solved");
      ck=0;
    }
  }
}
