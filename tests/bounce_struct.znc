make dot "bounce_struct.dot";

include "io.znc"

struct Obj {
  int x;
  int y;
  int dx;
  int dy;
  char c;
};

const int N=21;

Obj[N] balls;

for (int i=0; i<N; ++i) {
  balls[i].x = i;
  balls[i].y = i;
  balls[i].dx = 1;
  balls[i].dy = 1;
  balls[i].c = 'A' + i;
}

void move(Obj *o) {
  o.x += o.dx;
  o.y += o.dy;
  
  if (o.x == 0 || o.x == 31) o.dx = -o.dx;
  if (o.y == 0 || o.y == 21) o.dy = -o.dy;
}

nextreg(7,3);
Obj *ball;

for(;;) {
  ball = &balls[0];
  gotoxy(ball.x, ball.y);
  putc(' ');
  
  for(int i=0; i<N; ++i) {
    ball = &balls[i];
    move(ball);
    gotoxy(ball.x, ball.y);
    putc(ball.c);  
  }
  if ((in(0x7ffe) & 1) == 0) break;
}
  