make dot "banked.dot";

include "../dotn.znc"

// Forward declaration of banked functions
void greet(char *msg) bank(1);
void greet2(char *msg) bank(2);

greet("World!");
greet2("World2!");

bank(1) {
  org(0x8000);
  
  void greet(char *msg) {
    puts(msg);putc('\r');
  }
}

bank(2) {
  org(0x8000);

  void greet2(char *msg) {
    greet(msg);
  }
}