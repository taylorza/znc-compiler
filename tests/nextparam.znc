#ifndef NEXTPARAM__
const byte NEXTPARAM__=0x01;

int nextParam(int pos, char* param) {
    
    while (args[pos]>0 && args[pos]<=32) {
      pos++;
    }

    int i = 0;
    byte inquotes=0;
    byte inq=0;
    byte ch = args[pos+i];
    while ( (ch>32) || (inquotes==1 && ch==32)) {
      if( (i==0 && ch!=34)
          || (i>0 && inquotes==0)
          || (i>0 && inquotes==1 && ch!=34)
          ) {
        param[i-inq] = args[pos+i];
      } else {
        inquotes = (inquotes==0) ? 1 : 0;
        inq=1;
      }
      i++;
      ch = args[pos+i];
    }
    
    param[i] = 0; // Null-terminate the current parameter
    
    return pos+i;
}

#endif