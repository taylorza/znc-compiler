make dot "regextst.dot";

include "io.znc"
include "regex.znc"

void result(int b, char *msg) {
  puts(msg); puts(": ");
  if (b) {
    ink(4); puts("PASSED");
  } else {
    ink(2); puts("FAILED");
  }
  putc('\r');
  ink(0);
}

