make dot "spaceshooter.dot";

include "kbd.znc"
include "memory.znc"
include "rnd.znc"
include "sprite.znc"
include "ay.znc"
include "mmu.znc"
include "fileio.znc"

// ------------------------------------------------------------
// GAME CONSTANTS
// ------------------------------------------------------------
const byte MAX_BULLETS = 10;
const byte MAX_ALIENS = 5;

const byte PAT_ALIEN = 0;
const byte PAT_EXPLODE = 1;
const byte PAT_PLAYER = 6;
const byte PAT_BULLET = 7;

const byte SPR_PLAYER = 0;
const byte SPR_ALIEN  = 1;
const byte SPR_BULLET = 10;
const byte SPR_EXPLODE = 30;

const int START_X = 152;
const int START_Y = 180;

// ------------------------------------------------------------
// GAME STATE
// ------------------------------------------------------------
enum STATE {Title, Playing, GameOver, Quit};

struct Bullet {
  byte active;
  int x;
  int y;
  char dy;
};

Bullet[MAX_BULLETS] bullets;
Bullet *pbullet;

struct Alien {
  byte alive;
  int x;
  int y;
  char dy;

  byte expl_frame;
  byte expl_timer;
};

Alien[MAX_ALIENS] aliens;
Alien *pAlien;

byte cooldown = 0;
int px;
int py;
byte pexpl_frame;
byte pexpl_timer;

int score;
byte lives;
STATE game_state;

// ------------------------------------------------------------
// Spawn Alien
// ------------------------------------------------------------
Alien *newAlien;
void spawnAlien(byte n) {
  spr_hide(SPR_EXPLODE+n);
  
  newAlien = &aliens[n];

  newAlien.alive = 1;
  newAlien.x = rnd() % 304;
  newAlien.y = -16 - (rnd()%16);
  newAlien.dy = 1 + (rnd()%2);
  newAlien.expl_frame = 0;
  newAlien.expl_timer = 0;
}

// ------------------------------------------------------------
// Spawn Bullets
// ------------------------------------------------------------
byte spawnBullet(int x, int y, char dy) {
  pbullet = bullets;
  for(byte i=0; i<MAX_BULLETS;++i) {
    if (!pbullet.active) {
      pbullet.active = 1;
      pbullet.x = x;
      pbullet.y = y;
      pbullet.dy = dy;
      return 1;
    }
    ++pbullet;
  }
  return 0;
}

// ------------------------------------------------------------
// INITIALIZATION
// ------------------------------------------------------------
void cls() {
  memset(0x4000, 0, 40*32);
  out(0xfe,0);
}

void palette() {
  nextreg(0x43, 0b00100000); // Sprite palette 1
  nextreg(0x40, 0);          // Start index 0
  for(int i=0; i<256; ++i) {
    nextreg(0x41,i);        // Write palette color
  }
}

void loadsprites(char* filename, byte count) {
  byte fh = fopen(filename, M_EXIST | M_READ);

  byte page = mmualloc();
  if (page == 255) {
    fclose(fh);
    return;
  }

  byte oldpage = readreg(0x56);
  nextreg(0x56, page);

  for(byte i=0; i < count; ++i) {
    fread(fh, 0xc000, 256);
    spr_load(i, 0xc000, 256);
  }
  fclose(fh);

  nextreg(0x56, oldpage);
  mmufree(page);
}

const int START_BANK=0x4000;
const int START_MAP=0x4000;
const int START_TILES=0x4500;
const byte OFFSET_MAP = (START_MAP-START_BANK)>>8;
const byte OFFSET_TILES = (START_TILES-START_BANK)>>8;

void loadtiles(char* filename, byte count) {
  byte fh = fopen(filename, M_EXIST | M_READ);
  fread(fh, START_TILES, count*32);
  fclose(fh);
}

const byte PAL_ULA_1 = 0b00000000;
const byte PAL_ULA_2 = 0b01000000;
const byte PAL_L2_1 = 0b00010000;
const byte PAL_L2_2 = 0b01010000;
const byte PAL_SPR_1 = 0b00100000;
const byte PAL_SPR_2 = 0b01100000;
const byte PAL_TIL_1 = 0b00110000;
const byte PAL_TIL_2 = 0b01110000;

void loadpalette(byte palette, char *filename) {
  byte fh = fopen(filename, M_EXIST | M_READ);

  byte page = mmualloc();
  if (page == 255) {
    fclose(fh);
    return;
  }

  byte oldpage = readreg(0x56);
  nextreg(0x56, page);
  fread(fh, 0xc000, 512);
  fclose(fh);

  byte ctlpal = readreg(0x43);
  nextreg(0x43, (ctlpal & 0b10001111) | palette); 
  nextreg(0x40, 0);
  for(byte *p = 0xc000; p < 0xc000+512; ++p){
    nextreg(0x44, *p);
  }
  nextreg(0x56, oldpage);
  mmufree(page); 
}

void til_disable() {
  nextreg(0x6b, 0);
}

void til_enable() {
  nextreg(0x6b, 0b10100000);
  nextreg(0x6c, 0b00000000);
  nextreg(0x6e, OFFSET_MAP);
  nextreg(0x6f, OFFSET_TILES);
}

byte cx=0;
byte cy=0;

void print(char *s) {
  byte *p = START_MAP + (40*cy) + cx;
  char c;
  while ((c = *s++)) {
    if (c < 32 || c > 127) c = '?';
    if (c >= 'a' && c <= 'z') c -= 32;
    c -= 32;

    *p++ = c;
    if (++cx >= 40) {
      cx=0;
      ++cy;
    }
  }
}

void printat(byte x, byte y, char *s) {
  cx=x;
  cy=y;
  print(s);
}

void printnum(int n) {
  if (n==0) { print("0"); return; }

  if (n<0) {
    print("-");
    n=-n;
  }
  
  int div=10000;  
  while((n/div)==0) {
    div=div/10;
  }
  
  char[] s = {0,0};
  while(div) {
    s[0] = n/div+'0';
    print(s);
    n=n%div;			
    div=div/10;
  }
}

void init() {
  palette();
  rndseed();

  // Set sprite clip window
  nextreg(0x19,0);
  nextreg(0x19,255);
  nextreg(0x19,0);
  nextreg(0x19,191);

  nextreg(0x14, 0xe3);            // Global Transparency index
  nextreg(0x4a, 0xe3);            // Fallback Transparency index
  nextreg(0x4b, 0xe3);            // Sprite Transparency index
  nextreg(0x4c, 0x03);            // Tilemap Transparency index

  loadsprites("spaceshooter.spr", 8);
  loadtiles("spaceshooter.til", 60);
  loadpalette(PAL_TIL_1, "spaceshooter.pal");

  til_enable();
}

void title() {
  cls();
  spr_disable();

  game_state = STATE.Title;  
  printat(14,10, "SPACE SHOOTER");
  printat(16,13, "O - LEFT");
  printat(16,15, "P - RIGHT");
  printat(14,17, "SPACE - FIRE");
  printat(11,20, "PRESS FIRE TO START");
  printat(12,22, "PRESS 'Q' TO QUIT");

  while(game_state == STATE.Title) {
    updatekeys();
    if (is_pressed(' ')) game_state = STATE.Playing;
    if (is_pressed('q')) game_state = STATE.Quit;
  }
}

void game_over(){
  cls();
  spr_disable();

  printat(17, 12, "GAME OVER");
  printat(14, 15, "FINAL SCORE:"); printnum(score);
  printat(12, 18, "PRESS 'S' TO RESTART");

  while(!is_pressed('s')) {
      updatekeys();
      __asm__{ halt }
  }
  game_state = STATE.Title;
}

void updateHud() {
  printat(0,0, "SCORE:"); printnum(score); print(" ");
  printat(32,0, "LIVES:"); printnum(lives);
}

byte collision(int ax, int ay, int aw, int ah, 
               int bx, int by, int bw, int bh) {
  return (ax < bx + bw) &&
         (bx < ax + aw) &&
         (ay < by + bh) &&
         (by < ay + ah);
}

void play() {
  cls();
  spr_enable();
  til_enable();

  score=0;
  lives=3;
  px=START_X;
  py=START_Y;
  pexpl_timer = 0;
  pexpl_frame = 0;

  updateHud();

  for(byte i=0;i<MAX_BULLETS;++i) {
    bullets[i].active = 0;
  }

  for(byte i=0;i<MAX_ALIENS;++i) {
    spawnAlien(i);
  }
  // -----------------------------
  // GAME LOOP
  // -----------------------------
  while(game_state == STATE.Playing) {
    // -----------------------------
    // Frame sync
    // -----------------------------
    __asm__{ 
      halt 
    }
    if (cooldown) --cooldown;
    updatekeys();

    

    // -----------------------------
    // Player movement
    // -----------------------------
    if (pexpl_timer==0) {
      if (is_pressed('o') && px > 10) px -= 2;
      if (is_pressed('p') && px < 300) px += 2;
    }
    
    // -----------------------------
    // Player shooting
    // -----------------------------
    if (cooldown == 0 && is_pressed(' ')) {
      if (spawnBullet(px+7, py+10, -4)) {
        cooldown = 8;
        ay_shoot();      
      }
    }
    
    // -----------------------------
    // Bullets
    // -----------------------------
    pbullet = bullets;
    for (byte i=0;i<MAX_BULLETS;++i) {
      // Alien bullet movement
      if (pbullet.active) {
        pbullet.y += pbullet.dy;
        if (pbullet.y > 240 || pbullet.y < 0) {
          pbullet.active = 0;
          spr_hide(SPR_BULLET+i);
        } else if (pbullet.dy > 0) {    
          // Hit player?
          if (collision(pbullet.x, pbullet.y, 3, 6, px, py, 16, 16)) {
            pbullet.active = 0;
            pexpl_frame=0;
            pexpl_timer=20;
            ay_explode();
          }
        }
      }
      ++pbullet;
    }

    // -----------------------------
    // Aliens
    // -----------------------------
    pAlien = aliens;
    for (byte i=0;i<MAX_ALIENS;i=i+1) {
      if (pAlien.alive) {
        pAlien.y = pAlien.y + pAlien.dy;
        if (pAlien.y > 256) {
          spawnAlien(i);
          if (score > 0) 
            score -= 1;
          updateHud();
        }

        // -----------------------------
        // Alien shooting
        // -----------------------------
        if (pAlien.y > 40 && (rnd()%40)==0) {
          spawnBullet(pAlien.x + 7, pAlien.y + 16, pAlien.dy+1);
        }

        // -----------------------------
        // Bullet collision with alien
        // -----------------------------
        pbullet = bullets;
        for(byte j=0;j<MAX_BULLETS;++j) {
          if (pbullet.active && pbullet.dy<0) {
            //if (pbullet.x+6 > pAlien.x && pbullet.x+8 < pAlien.x+16 &&
            //  pbullet.y+5 > pAlien.y && pbullet.y+10 < pAlien.y+16) {
            if (collision(pbullet.x, pbullet.y, 3, 6, pAlien.x, pAlien.y, 16, 16)) {
              pAlien.alive = 0;
              pbullet.active=0;
              pAlien.expl_frame = 0;
              pAlien.expl_timer = 20;            
              score += 10;
              updateHud();
              ay_explode();            
            }
          }
          ++pbullet;
        } 

         // -----------------------------
        // Alien collision with player
        // -----------------------------        
        if (collision(pAlien.x+1, pAlien.y+2, 14, 13, px+1, py+1, 14, 14)) {
          pAlien.alive = 0;
          pAlien.expl_frame = 0;
          pAlien.expl_timer = 20;
          pexpl_frame=0;
          pexpl_timer=20;          
          ay_explode();            
        }        
      }
    
      // -----------------------------
      // Explosion animation
      // -----------------------------
      if (pAlien.expl_timer > 0) {
        pAlien.expl_timer = pAlien.expl_timer - 1;
        if (pAlien.expl_timer % 5 == 0) {
          pAlien.expl_frame = pAlien.expl_frame + 1;
        }
      }   

      ++pAlien; 
    }
    
    // -----------------------------
    // DRAW SPRITES
    // -----------------------------
    if (pexpl_timer > 0) {
      spr_hide(SPR_PLAYER);

      if (pexpl_frame < 4) {
        spr_update(SPR_EXPLODE+20, PAT_EXPLODE+pexpl_frame, px, py, 0);
      }
      --pexpl_timer;
      if (pexpl_timer%5 == 0) ++pexpl_frame;
      if (pexpl_timer==0) {
        spr_hide(SPR_EXPLODE+20);
        --lives;        
        if (lives == 0) {
          game_state = STATE.GameOver;
        } else {
          px=START_X;
          py=START_Y;
        }
        updateHud();
      }
    } else {
      spr_update(SPR_PLAYER,PAT_PLAYER,px,py,0);
    }

    pAlien = aliens;
    for (byte i=0;i<MAX_ALIENS;i=i+1) {
      if (pAlien.alive) {
        spr_update(SPR_ALIEN+i,PAT_ALIEN,pAlien.x,pAlien.y,0);
      } else if (pAlien.expl_timer > 0) {
        spr_hide(SPR_ALIEN+i);

        if (pAlien.expl_frame < 3) {        
          spr_update(SPR_EXPLODE+i,PAT_EXPLODE+pAlien.expl_frame,pAlien.x,pAlien.y,0);        
        } else {        
          spawnAlien(i);
        }
      } else {
        spr_hide(SPR_EXPLODE+i);
        spr_hide(SPR_ALIEN+i);
      }
      ++pAlien;
    } 

    pbullet = bullets;
    for (byte i=0;i<MAX_BULLETS;++i) {
      if (pbullet.active) {
        spr_update(SPR_BULLET+i,PAT_BULLET,pbullet.x,pbullet.y,0);
      } else {
        spr_hide(SPR_BULLET+i);
      }
      ++pbullet;
    }
  }
}

init();

// -----------------------------
// GAME LOOP
// -----------------------------
while(game_state != STATE.Quit) {
  switch(game_state) {
    case STATE.Title: title(); break;
    case STATE.Playing: play(); break;
    case STATE.GameOver: game_over(); break;
  }
}

spr_disable();
til_disable();