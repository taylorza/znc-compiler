// ------------------------------------------------------------
// GAME CONSTANTS
// ------------------------------------------------------------
const byte MAX_BULLETS = 10;
const byte MAX_ALIENS = 5;
const byte SPR_PLAYER = 0;
const byte SPR_ALIEN  = 1;
const byte SPR_BULLET = 10;
const byte SPR_EXPLODE = 30;

// ------------------------------------------------------------
// GAME STATE
// ------------------------------------------------------------
struct Bullet {
  byte active;
  int x;
  int y;
  char dy;
};

int px = 120;
int py = 180;

int[MAX_ALIENS] ax;
int[MAX_ALIENS] ay;
char[MAX_ALIENS] ady;
byte[MAX_ALIENS] alive;

Bullet[MAX_BULLETS] bullets;
Bullet *pbullet;

byte[MAX_ALIENS] expl_frame;
byte[MAX_ALIENS] expl_timer;

// ------------------------------------------------------------
// Spawn Alien
// ------------------------------------------------------------
void spawnAlien(byte n) {  
  ay[n] = -32;
  ady[n] = 1 + (rnd()%2);
  alive[n] = 1;
  expl_frame[n] = 0;
  expl_timer[n] = 0;

  spr_hide(SPR_EXPLODE+n);
  for(;;) {    
    byte overlap = 0;
    int x = rnd() % 304;
    for (byte i=0; i<MAX_ALIENS;++i) {
      if (n == i) continue;
      if (!alive[i]) continue;

      if (x < ax[i]+16 && x+16 > ax[i]) {
        overlap = 1;
      }
    }
    if (!overlap) {
      ax[n] = x;
      break;
    }
  }
}

// ------------------------------------------------------------
// Spawn Bullets
// ------------------------------------------------------------
byte spawnBullet(int x, int y, char dy) {
  pbullet = bullets;
  for(byte i=0; i<MAX_BULLETS;++i) {
    if (!pbullet.active) {
      pbullet.active = 1;
      pbullet.x = x;
      pbullet.y = y;
      pbullet.dy = dy;
      return 1;
    }
    ++pbullet;
  }
  return 0;
}

// ------------------------------------------------------------
// INITIALIZATION
// ------------------------------------------------------------
void cls() {
  memset(0x4000, 0, 0x1800);
  memset(0x5800, 7, 0x300);
  out(0xfe,0);
  ink(7);
  paper(0);
}

void palette() {
  nextreg(0x43, 0b00100000); // Sprite palette 1
  nextreg(0x40, 0);         // Start index 0
  for(int i=0; i<256; ++i) {
    nextreg(0x41,i);        // Write palette color
  }
}

void init() {
  palette();
  cls();
  rndseed();

  spr_load(0, ship, 16*16);
  spr_load(1, alien, 16*16);
  spr_load(10, bullet, 16*16);
  spr_load(30, explode0, 16*16);
  spr_load(31, explode1, 16*16);
  spr_load(32, explode2, 16*16);
  spr_load(33, explode3, 16*16);

  spr_enable();

  for (int i=0;i<256;++i){
    spr_hide(i);
  }

  pbullet = bullets;
  for (byte i=0;i<MAX_BULLETS;++i) {
    pbullet.active = 0;    
  }

  for(byte i=0;i<MAX_ALIENS;++i) {
    spawnAlien(i);
  }
}

// ------------------------------------------------------------
// MAIN LOOP
// ------------------------------------------------------------

init();
byte lives = 1;
byte cooldown = 0;

while(lives) {
  // -----------------------------
  // Frame sync
  // -----------------------------
  __asm__{ 
    halt 
  }
  if (cooldown) --cooldown;
  updatekeys();

  // Quit on ESC
  if (is_pressed('a')) break;

  // -----------------------------
  // Player movement
  // -----------------------------
  if (is_pressed('o') && px > 10) px = px - 2;
  if (is_pressed('p') && px < 300) px = px + 2;
  
  // -----------------------------
  // Player shooting
  // -----------------------------
  if (cooldown == 0 && is_pressed(' ')) {
    if (spawnBullet(px+1, py-4, -4)) {
      cooldown = 8;
      ay_shoot();
    }
  }
  
  // -----------------------------
  // Bullets
  // -----------------------------
  pbullet = bullets;
  for (byte i=0;i<MAX_BULLETS;++i) {
    // Alien bullet movement
    if (pbullet.active) {
      pbullet.y += pbullet.dy;
      if (pbullet.y > 240 || pbullet.y < 0) {
        pbullet.active = 0;
        spr_hide(SPR_BULLET+i);
      } else if (pbullet.dy > 0) {    
        // Hit player?
        if (pbullet.y > py && pbullet.y < py+16 &&
          pbullet.x > px-8 && pbullet.x < px+24) {
          //ay_explode();
          //--lives;
          pbullet.active = 0;
        }
      }
    }
    ++pbullet;
  }

  // -----------------------------
  // Aliens
  // -----------------------------
  for (byte i=0;i<MAX_ALIENS;i=i+1) {
    if (alive[i]) {
      ay[i] = ay[i] + ady[i];
      if (ay[i] > 256 + (rnd()%40)) {
        spawnAlien(i);
      }
    
      // Alien shooting
      if (ay[i] > 40 && (rnd()%40)==0) {
        spawnBullet(ax[i], ay[i] + 6, ady[i]+1);
      }

      // -----------------------------
      // Bullet collision with alien
      // -----------------------------
      pbullet = bullets;
      for(byte j=0;j<MAX_BULLETS;++j) {
        if (pbullet.active && pbullet.dy<0) {
          if (pbullet.x+6 > ax[i] && pbullet.x+8 < ax[i]+16 &&
            pbullet.y+5 > ay[i] && pbullet.y+10 < ay[i]+16) {
            alive[i] = 0;
            pbullet.active=0;
            expl_frame[i] = 0;
            expl_timer[i] = 20;            
            ay_explode();
          }
        }
        ++pbullet;
      }
    }
  
    // Explosion animation
    if (expl_timer[i] > 0) {
      expl_timer[i] = expl_timer[i] - 1;
      if (expl_timer[i] % 5 == 0) {
        expl_frame[i] = expl_frame[i] + 1;
      }
    }    
  }
  
  // -----------------------------
  // DRAW SPRITES
  // -----------------------------
  spr_update(SPR_PLAYER,0,px,py,0);

  for (byte i=0;i<MAX_ALIENS;i=i+1) {
    if (alive[i]) {
      spr_update(SPR_ALIEN+i,1,ax[i],ay[i],0);
    } else if (expl_timer[i] > 0) {
      spr_hide(SPR_ALIEN+i);

      if (expl_frame[i] < 3) {        
        spr_update(SPR_EXPLODE+i,30+expl_frame[i],ax[i],ay[i],0);        
      } else {        
        spawnAlien(i);
      }
    } else {
      spr_hide(SPR_EXPLODE+i);
      spr_hide(SPR_ALIEN+i);
    }
  } 

  pbullet = bullets;
  for (byte i=0;i<MAX_BULLETS;++i) {
    if (pbullet.active) {
      spr_update(SPR_BULLET+i,10,pbullet.x,pbullet.y,0);
    } else {
      spr_hide(SPR_BULLET+i);
    }
    ++pbullet;
  }
}

spr_disable();
