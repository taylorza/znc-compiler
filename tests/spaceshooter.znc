// ------------------------------------------------------------
// GAME CONSTANTS
// ------------------------------------------------------------
const byte MAX_BULLETS = 10;
const byte MAX_ALIENS = 5;
const byte SPR_PLAYER = 0;
const byte SPR_ALIEN  = 1;
const byte SPR_BULLET = 10;
const byte SPR_EXPLODE = 30;

const int START_X = 152;
const int START_Y = 180;

// ------------------------------------------------------------
// GAME STATE
// ------------------------------------------------------------
enum STATE {Title, Playing, GameOver, Quit};

struct Bullet {
  byte active;
  int x;
  int y;
  char dy;
};

Bullet[MAX_BULLETS] bullets;
Bullet *pbullet;

struct Alien {
  byte alive;
  int x;
  int y;
  char dy;

  byte expl_frame;
  byte expl_timer;
};

Alien[MAX_ALIENS] aliens;
Alien *pAlien;

byte cooldown = 0;
int px;
int py;
byte pexpl_frame;
byte pexpl_timer;

int score;
byte lives;
STATE game_state;

// ------------------------------------------------------------
// Spawn Alien
// ------------------------------------------------------------
Alien *newAlien;
Alien *curAlien;
void spawnAlien(byte n) {
  newAlien = &aliens[n];

  newAlien.alive = 1;
  newAlien.y = -32;
  newAlien.dy = 1 + (rnd()%2);
  newAlien.expl_frame = 0;
  newAlien.expl_timer = 0;
  
  spr_hide(SPR_EXPLODE+n);
  for(;;) {    
    byte overlap = 0;
    int x = rnd() % 304;
    for (byte i=0; i<MAX_ALIENS;++i) {
      curAlien = &aliens[i];
      if (n == i) continue;
      if (!curAlien.alive) continue;

      if (x < curAlien.x+16 && x+16 > curAlien.x) {
        overlap = 1;
      }
    }
    if (!overlap) {
      newAlien.x = x;
      break;
    }
  }
}

// ------------------------------------------------------------
// Spawn Bullets
// ------------------------------------------------------------
byte spawnBullet(int x, int y, char dy) {
  pbullet = bullets;
  for(byte i=0; i<MAX_BULLETS;++i) {
    if (!pbullet.active) {
      pbullet.active = 1;
      pbullet.x = x;
      pbullet.y = y;
      pbullet.dy = dy;
      return 1;
    }
    ++pbullet;
  }
  return 0;
}

// ------------------------------------------------------------
// INITIALIZATION
// ------------------------------------------------------------
void cls() {
  memset(0x4000, 0, 0x1800);
  memset(0x5800, 7, 0x300);
  out(0xfe,0);
  ink(7);
  paper(0);
}

void palette() {
  nextreg(0x43, 0b00100000); // Sprite palette 1
  nextreg(0x40, 0);         // Start index 0
  for(int i=0; i<256; ++i) {
    nextreg(0x41,i);        // Write palette color
  }
}

void init() {
  palette();
  rndseed();

  // Set sprite clip window
  nextreg(0x19,0);
  nextreg(0x19,255);
  nextreg(0x19,0);
  nextreg(0x19,191);

  spr_load(0, ship, 16*16);
  spr_load(1, alien, 16*16);
  spr_load(10, bullet, 16*16);
  spr_load(30, explode0, 16*16);
  spr_load(31, explode1, 16*16);
  spr_load(32, explode2, 16*16);
  spr_load(33, explode3, 16*16);
}

void title() {
  cls();
  spr_disable();

  game_state = STATE.Title;  
  gotoxy(10,10); puts("SPACE SHOOTER");
  gotoxy(7,12); puts("PRESS FIRE TO START");
  gotoxy(8,15); puts("PRESS 'Q' TO QUIT");

  while(game_state == STATE.Title) {
    updatekeys();
    if (is_pressed(' ')) game_state = STATE.Playing;
    if (is_pressed('q')) game_state = STATE.Quit;
  }
}

void game_over(){
  cls();
  spr_disable();

  gotoxy(11,8); puts("GAME OVER");
  gotoxy(8,12); puts("FINAL SCORE:"); printnum(score);
  gotoxy(6,16); puts("PRESS 'S' TO RESTART");

  while(!is_pressed('s')) {
      updatekeys();
      __asm__{ halt }
  }
  game_state = STATE.Title;
}

void play() {
  cls();
  spr_enable();

  score=0;
  lives=3;
  px=START_X;
  py=START_Y;
  pexpl_timer = 0;
  pexpl_frame = 0;

  for(byte i=0;i<MAX_BULLETS;++i) {
    bullets[i].active = 0;
  }

  for(byte i=0;i<MAX_ALIENS;++i) {
    spawnAlien(i);
  }
  // -----------------------------
  // GAME LOOP
  // -----------------------------
  while(game_state == STATE.Playing) {
    // -----------------------------
    // Frame sync
    // -----------------------------
    __asm__{ 
      halt 
    }
    if (cooldown) --cooldown;
    updatekeys();

    gotoxy(0,0); puts("SCORE:"); printnum(score);
    gotoxy(20,0); puts("LIVES:"); printnum(lives);

    // -----------------------------
    // Player movement
    // -----------------------------
    if (pexpl_timer==0) {
      if (is_pressed('o') && px > 10) px -= 2;
      if (is_pressed('p') && px < 300) px += 2;
    }
    
    // -----------------------------
    // Player shooting
    // -----------------------------
    if (cooldown == 0 && is_pressed(' ')) {
      if (spawnBullet(px+1, py-4, -4)) {
        cooldown = 8;
        ay_shoot();      
      }
    }
    
    // -----------------------------
    // Bullets
    // -----------------------------
    pbullet = bullets;
    for (byte i=0;i<MAX_BULLETS;++i) {
      // Alien bullet movement
      if (pbullet.active) {
        pbullet.y += pbullet.dy;
        if (pbullet.y > 240 || pbullet.y < 0) {
          pbullet.active = 0;
          spr_hide(SPR_BULLET+i);
        } else if (pbullet.dy > 0) {    
          // Hit player?
          if (pbullet.y > py && pbullet.y < py+16 &&
            pbullet.x > px-8 && pbullet.x < px+24) {
            pbullet.active = 0;
            pexpl_frame=0;
            pexpl_timer=20;
            ay_explode();
          }
        }
      }
      ++pbullet;
    }

    // -----------------------------
    // Aliens
    // -----------------------------
    pAlien = aliens;
    for (byte i=0;i<MAX_ALIENS;i=i+1) {
      if (pAlien.alive) {
        pAlien.y = pAlien.y + pAlien.dy;
        if (pAlien.y > 256 + (rnd()%40)) {
          spawnAlien(i);
        }

        // -----------------------------
        // Alien shooting
        // -----------------------------
        if (pAlien.y > 40 && (rnd()%40)==0) {
          spawnBullet(pAlien.x, pAlien.y + 6, pAlien.dy+1);
        }

        // -----------------------------
        // Bullet collision with alien
        // -----------------------------
        pbullet = bullets;
        for(byte j=0;j<MAX_BULLETS;++j) {
          if (pbullet.active && pbullet.dy<0) {
            if (pbullet.x+6 > pAlien.x && pbullet.x+8 < pAlien.x+16 &&
              pbullet.y+5 > pAlien.y && pbullet.y+10 < pAlien.y+16) {
              pAlien.alive = 0;
              pbullet.active=0;
              pAlien.expl_frame = 0;
              pAlien.expl_timer = 20;            
              score += 10;
              ay_explode();            
            }
          }
          ++pbullet;
        } 
      }
    
      // -----------------------------
      // Explosion animation
      // -----------------------------
      if (pAlien.expl_timer > 0) {
        pAlien.expl_timer = pAlien.expl_timer - 1;
        if (pAlien.expl_timer % 5 == 0) {
          pAlien.expl_frame = pAlien.expl_frame + 1;
        }
      }   

      ++pAlien; 
    }
    
    // -----------------------------
    // DRAW SPRITES
    // -----------------------------
    if (pexpl_timer > 0) {
      spr_hide(SPR_PLAYER);

      if (pexpl_frame < 3) {
        spr_update(SPR_EXPLODE+20, 30+pexpl_frame, px, py, 0);
      }
      --pexpl_timer;
      if (pexpl_timer%5 == 0) ++pexpl_frame;
      if (pexpl_timer==0) {
        spr_hide(SPR_EXPLODE+20);
        --lives;
        if (lives == 0) {
          game_state = STATE.GameOver;
        } else {
          px=START_X;
          py=START_Y;
        }
      }
    } else {
      spr_update(SPR_PLAYER,0,px,py,0);
    }

    pAlien = aliens;
    for (byte i=0;i<MAX_ALIENS;i=i+1) {
      if (pAlien.alive) {
        spr_update(SPR_ALIEN+i,1,pAlien.x,pAlien.y,0);
      } else if (pAlien.expl_timer > 0) {
        spr_hide(SPR_ALIEN+i);

        if (pAlien.expl_frame < 3) {        
          spr_update(SPR_EXPLODE+i,30+pAlien.expl_frame,pAlien.x,pAlien.y,0);        
        } else {        
          spawnAlien(i);
        }
      } else {
        spr_hide(SPR_EXPLODE+i);
        spr_hide(SPR_ALIEN+i);
      }
      ++pAlien;
    } 

    pbullet = bullets;
    for (byte i=0;i<MAX_BULLETS;++i) {
      if (pbullet.active) {
        spr_update(SPR_BULLET+i,10,pbullet.x,pbullet.y,0);
      } else {
        spr_hide(SPR_BULLET+i);
      }
      ++pbullet;
    }
  }
}

init();

// -----------------------------
// GAME LOOP
// -----------------------------
while(game_state != STATE.Quit) {
  switch(game_state) {
    case STATE.Title: title(); break;
    case STATE.Playing: play(); break;
    case STATE.GameOver: game_over();
  }
}

spr_disable();
