make dot "hexedit.dot";
//make dot "/dot/hexedit";

include "mmu.znc"
include "fileio.znc"
include "memory.znc"
include "font.inc"

const byte ROWS=28;
const byte COLS=16;

const int TILE_MAP = 0x4000;
const int TILE_DEF = 0x5400;
const byte OFFSET_MAP = 0;
const byte OFFSET_DEF = (TILE_DEF - TILE_MAP) >> 8;

const int SCREEN_WIDTH = 80;
const int SCREEN_WIDTH2 = SCREEN_WIDTH << 1;
const int SCREEN_HEIGHT = 32;
const byte gutter = 2;

struct u32 {
  byte b0;
  byte b1;
  byte b2;
  byte b3;
}

void u32_addi(u32 *a, int b) __znccall(1) {
  u32 r;
  
  int sum;
  int carry = 0;
  
  int b_b0 = b & 0xff;
  int b_b1 = (b >> 8) & 0xff;
  int b_ext = (b < 0) ? 0xff : 0;

  sum = a.b0 + b_b0;
  r.b0 = sum & 0xff;
  carry = (sum >> 8) & 1;

  sum = a.b1 + b_b1 + carry;
  r.b1 = sum & 0xff;
  carry = (sum >> 8) & 1;

  sum = a.b2 + b_ext + carry;
  r.b2 = sum & 0xff; 
  carry = (sum >> 8) & 1;

  sum = a.b3 + b_ext + carry;
  r.b3 = sum & 0xff;

  *a = r;
}

void u32_sub(u32 *a, u32 *b) __znccall(1) {
  int t;
  byte borrow;

  t = a.b0 - b.b0;
  a.b0 = t;
  borrow = (t < 0);

  t = a.b1 - b.b1 - borrow;
  a.b1 = t;
  borrow = (t < 0);

  t = a.b2 - b.b2 - borrow;
  a.b2 = t;
  borrow = (t < 0);

  t = a.b3 - b.b3 - borrow;
  a.b3 = t;
}

int u32_scmp(u32 *a, u32 *b) __znccall(1) {
  char sa3 = a.b3; int ab3 = sa3;
  char sb3 = b.b3; int bb3 = sb3;

  int d = ab3 - bb3;
  if (d) return d;

  if (a.b2 != b.b2) return (a.b2 < b.b2) ? -1 : 1;
  if (a.b1 != b.b1) return (a.b1 < b.b1) ? -1 : 1;
  if (a.b0 != b.b0) return (a.b0 < b.b0) ? -1 : 1;

  return 0;
}

// CRT cursor location
byte cx = 0;
byte cy = 0;
byte attr = 0;

void gotoxy(byte x, byte y) __znccall(1) {
  cx = x;
  cy = y;
};

void putch(char ch) __znccall(1) {
  char *p = TILE_MAP + (((cy * SCREEN_WIDTH) + cx) << 1);
  *p++ = ch - 32;
  *p = attr;
  ++cx;
  if (cx == SCREEN_WIDTH) {
    cx = 0;
    ++cy;
  }
}

byte putstr(char *s) __znccall(1) {
  byte n = 0;
  char *p = TILE_MAP + (((cy * SCREEN_WIDTH) + cx) << 1);
  while (*s) {
    *p++ = *s++ - 32;
    *p++ = attr;
    ++cx;
    ++n;
    if (cx == SCREEN_WIDTH) {
      cx = 0;
      ++cy;
    }
  }
  return n;
}

char[] hex="0123456789ABCDEF";
void puthex(byte b) __znccall(1) {
  putch(hex[(b >> 4) & 0x0f]);
  putch(hex[b & 0x0f]);
}

void print_u32(u32 *v) __znccall(1) {
  puthex(v.b3); puthex(v.b2);
  putch(':');
  puthex(v.b1); puthex(v.b0);
}

void setattr(byte attr) __znccall(1) {
  char *p = TILE_MAP + (((cy * SCREEN_WIDTH) + cx) << 1) + 1;
  *p = (attr << 1);
}

void inverse() {
  attr ^= 1 << 1;
}

void cls() {
  memset(TILE_MAP, 0, 6144);
}

void clreol() {
  char *p = TILE_MAP + (((cy * SCREEN_WIDTH) + cx) << 1);
  memset(p, 0, (SCREEN_WIDTH - cx) << 1);
}

void scroll_up(byte lines) __znccall(1) {
  int movebytes = (ROWS - lines) * SCREEN_WIDTH2;
  memcpy(TILE_MAP, TILE_MAP + lines * SCREEN_WIDTH2, movebytes);
  memset(TILE_MAP + movebytes, 0, lines * SCREEN_WIDTH2);
}

void scroll_down(byte lines) __znccall(1) {
  int movebytes = (ROWS - lines) * SCREEN_WIDTH2;
  memmove(TILE_MAP + lines * SCREEN_WIDTH2, TILE_MAP, movebytes);
  memset(TILE_MAP, 0, lines * SCREEN_WIDTH2);
}

char inkey() __asm__ {
  ld hl,0
  bit 5,(iy+1)
  ret z
  res 5,(iy+1)
  ld a,($5c08)
  ld l,a
  ret 
}

byte flashctr = 0;
char key;
char lastkey;
void getch() {
    setattr(1);
    lastkey = key;
    while ((key = inkey()) == 0) {
      __asm__{
        halt
      }
      ++flashctr;
      if (flashctr == 15) setattr(0);
      else if (flashctr == 30){ setattr(1); flashctr = 0;}
    }
    setattr(0);
}

// mmu state
byte[111] pages;
byte pagecount;
u32 size = {0,0,0,0};

// Save next registers
byte old_reg_07 = readreg(0x07);
byte old_reg_43 = readreg(0x43);
byte old_reg_6b = readreg(0x6b);

byte old_slot_6 = readreg(0x56);

// Save the border color
byte old_border = (*0x5c48 & 0b00111000) >> 3;

void init() {
  nextreg(0x07, 3);           // ===== Go fast!!!
  
  cls();

  // Tilemap Palette
  nextreg(0x43, 0b00110000);
  nextreg(0x40, 0);
  nextreg(0x41, 0b00000010); // 0-Blue
  nextreg(0x41, 0b11111100); // 1-Yellow
  nextreg(0x41, 0b11111100); // 0-Yellow
  nextreg(0x41, 0b00000010); // 1-Blue

  nextreg(0x6b, 0b11001001); // 80x32 text mode with attributes
  nextreg(0x6e, OFFSET_MAP);
  nextreg(0x6f, OFFSET_DEF);

  // Set tilemap defaults
  // Reset clip window
  nextreg(0x1c, 0b00001000);      // Reset tilemap clip index
  nextreg(0x1b, 0);               // X1 - 0
  nextreg(0x1b, 159);             // X2 - 318
  nextreg(0x1b, 0);               // Y1 - 0
  nextreg(0x1b, 255);             // Y1 - 255

  // Reset scroll offsets
  nextreg(0x2f, 0);               // X Scroll offset - MSB
  nextreg(0x30, 0);               // X Scroll offset - LSB
  nextreg(0x31, 0);               // Y Scroll offset

  // Copy the font to the tile definitions
  memcpy(TILE_DEF, font, 888);

  // Set the border to Blue (assume the default ULA palette)
  out(0xfe,1);
}

int lastpagesize = -1;

void error(char *msg) __znccall(1);
void confirm(char *msg) __znccall(1) ;

void loadfile(char* file) __znccall(1) {
  errno=0;
  byte f=fopen(args,M_READ);
  if (errno != 0) error("Could not open file");

  for(;;) {
    byte page = mmualloc();
    if (page == 255) {
      fclose(f);
      error("out of memory");
    }
  
    pages[pagecount++] = page;
    nextreg(0x56, page);
    int bytesRead = fread(f, 0xC000, 8192);
    if (!bytesRead) break;
    lastpagesize = bytesRead;
    u32_addi(&size, bytesRead);
  }

  fclose(f);
}

void savefile(char *file) __znccall(1) {
  errno=0;
  byte f=fopen(args, M_EXIST | M_WRITE);
  if (errno != 0) {
    if (confirm("Save failed. Exit")) {
      exit(0);
    }
    return;
  }

  for(byte i=0; i < pagecount - 2; ++i) {
    nextreg(0x56, pages[i]);
    fwrite(f, 0xc000, 8192);
  }
  nextreg(0x56, pages[pagecount - 2]);
  fwrite(f, 0xc000, lastpagesize);
  fclose(f);
}

int pagein(u32 *addr) __znccall(1) {
  int lo = addr.b0 | (addr.b1 << 8);
  int hi = addr.b2 | (addr.b3 << 8);
  byte page = ((hi << 3) & 0xfff8) | (lo >> 13);
  int offset = lo & 0x1fff;
  
  nextreg(0x56, pages[page]);
  return offset;
}

const char KEY_LEFT = 0x08;
const char KEY_RIGHT = 0x09;
const char KEY_DOWN = 0x0a;
const char KEY_UP   = 0x0b;

const char KEY_EXT = 0x0e;

char[COLS+1] ascii;
byte dump(u32 *addr) {
  print_u32(addr); putstr("  ");

  u32 curr = *addr;  
  byte *p = 0xC000 + pagein(addr);
  byte i = 0;
  while(i < COLS && u32_scmp(&curr, &size) < 0) {
    byte b = *p++;
    puthex(b); putch(' ');
    ascii[i] = (b < 32 || b > 126) ? '.' : b;
    
    u32_addi(&curr, 1);
    ++i;    
  }
  byte printed = i;

  while(i < COLS) {
    putstr("   ");
    ascii[i++] = ' ';    
  }
  ascii[COLS]=0;
  putch(' ');
  putstr(ascii);

  return printed;      
}

u32 ZERO = {0,0,0,0};

u32 from = {0,0,0,0};
u32 curr;
u32 tmp;
byte curr_row;

byte inview(u32 *t) __znccall(1) {
  u32 end = from;
  u32_addi(&end, ROWS * COLS);
  if (u32_scmp(&end, &size) > 0) end = size;
  return u32_scmp(t, &from) >= 0 && u32_scmp(t, &end) < 0;
}

byte goto_addr(u32 *t, byte h) __znccall(1) {
  if (u32_scmp(t, &from) < 0) {
    gotoxy(gutter + 11 + h, 0);
    return 0;
  }

  byte r;
  byte offset;
  u32 delta = *t;
  u32_sub(&delta, &from);

  if (delta.b2 != 0 || delta.b3 != 0) {
    r = ROWS-1;
    offset = COLS-1;
    gotoxy(gutter + 11 + h + offset * 3, r);
    return r;
  }

  int d16 = (delta.b1 << 8) | delta.b0;
  if (d16 >= ROWS * COLS) {
    r = ROWS - 1;
    offset = COLS - 1;
    gotoxy(gutter + 11 + h + offset * 3, r);
    return r;
  }

  r = d16 >> 4;
  offset = d16 & 0x0f;
  gotoxy(gutter + 11 + h + offset * 3, r);
  return r;
}

void downrow() {
  scroll_up(1);
  u32 addr = from;
  u32_addi(&addr, ROWS * COLS);
  gotoxy(gutter, ROWS-1);
  dump(&addr);  
  u32_addi(&from, COLS);
}

void uprow() {
  scroll_down(1);      
  u32_addi(&from, -COLS);
  u32 addr = from;
  gotoxy(gutter, 0);
  dump(&addr);
}

void moveright() {   
  tmp = curr;
  u32_addi(&tmp, 1);
  if (u32_scmp(&tmp, &size) < 0) curr = tmp;  
}

void menuitem(char key, char* name, byte active) __znccall(1) {
  byte w = 10;
  if (active) inverse();
  putch('^'); putch(key); 
  if (active) inverse();
  putch(' '); w -= putstr(name);
  while(--w) putch(' ');
}

void menu(byte active) __znccall(1) {
  gotoxy(0,29);
  menuitem('S',"Save", active);
  menuitem('Q',"Quit", active);
}

byte confirm(char *msg) __znccall(1) {
  gotoxy(0, 28); putstr(msg); putstr(" (Y/N)?");
  getch();
  gotoxy(0,28); clreol();
  return key == 'y' || key == 'Y';
}

byte running;
byte dirty;
void edit() {
  byte n;
  byte h = 0;
  from = ZERO;

  menu(0);
  gotoxy(0,31); putstr("Filename:"); putstr(args);
  
  for (byte i = 0; i < ROWS; ++i) {
    tmp = from;
    u32_addi(&tmp, i * COLS);
    gotoxy(gutter, i);
    dump(&tmp);    
    if (u32_scmp(&tmp, &size) >= 0) break;
  }  

  running = 1;
  dirty = 0;
  while(running) {
    gotoxy(71,31);
    print_u32(&curr);
  
    curr_row = goto_addr(&curr, h);
    
    getch();
    
    if (lastkey == KEY_EXT) {
      menu(0);
      switch(key) {
        case KEY_EXT:
          lastkey = key = 0;
          break;
        case 'q':
        case 'Q':
          if (dirty) {
            if (!confirm("Loose changes")) continue;
          }
          running = 0;
          break;
        case 's':
        case 'S':
          if (dirty && confirm("Overwrite file")) {
            savefile(args);
            dirty = 0;
          }
          break;
      }
      continue;
    } else if (key == KEY_EXT) {
      menu(1);
    }

    switch(key) {
      case KEY_LEFT:
        if (!h) {
          tmp = curr;
          u32_addi(&tmp, -1);
          if (u32_scmp(&tmp, &ZERO) >= 0) curr = tmp;
        }
        h ^= 1;
        break;
      
      case KEY_RIGHT:
        if (h) moveright();
        h ^= 1;
        break;

      case KEY_DOWN:
        tmp = curr;
        u32_addi(&tmp, COLS);
        if (u32_scmp(&tmp, &size) < 0) curr = tmp;
        break;
      
      case KEY_UP:
        tmp = curr;
        u32_addi(&tmp, -COLS);        
        if (u32_scmp(&tmp, &ZERO) >= 0) curr = tmp;
        break;

      default:
        byte nibble = 255;
        if (key >= '0' && key <= '9') nibble = key - '0';
        else if (key >= 'a' && key <= 'f') nibble = key - 'a' + 10;        

        if (nibble != 255) {
          int offset = pagein(&curr);
          byte *p = 0xC000 + offset;
          if (!h) *p = (*p & 0x0f) | (nibble << 4);
          else *p = (*p & 0xf0) | nibble;
          tmp = curr;
          tmp.b0 &= 0xf0;
          gotoxy(gutter, curr_row); dump(&tmp);          
          if (h) moveright();
          h ^= 1;
          dirty = 1;
        }
        break;
    }
    while (!inview(&curr)) {
      if (u32_scmp(&curr, &from) < 0)
        uprow();
      else
        downrow();
    }
  }
}

void cleanup() {
  for(byte i = 0; i < pagecount; ++i) {
    mmufree(pages[i]);
  }

  cls();

  // Restore the border color
  out(0xfe, old_border);

  // Restore the next registers
  nextreg(0x56, old_slot_6);

  nextreg(0x6b, old_reg_6b);
  nextreg(0x43, old_reg_43);

 nextreg(0x07, old_reg_07);
}

void error(char *msg) __znccall(1) {
  cleanup();
  exit(msg);
}

if (*args == 0) {
  puts("HEX Editor v1.0\r\r");
  puts(".hexedit <filename>\r");
  exit(0);
}

loadfile(args);

init();
edit();
cleanup();
