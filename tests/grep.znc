make dot "grep.dot";

include "dotn.znc"
include "fileio.znc"
include "dirinfo.znc"
include "cmdline.znc"
include "regex.znc"
include "memory.znc"
include "string.znc"

void showhelp() bank(1);
byte scan_text(char* filename, char* pattern) bank(1);

const int LINE_SIZE = 8192;
const int HALF_LINE = LINE_SIZE / 2;
const byte MAX_ARGS = 2;

const int LINE_BUF = 0xC000;

struct u24 {
  byte b0;
  byte b1;
  byte b2;
}

void u24_inc(u24 *n) {
  n.b0++;
  if (n.b0 != 0) return;
  n.b1++;
  if (n.b1 != 0) return;
  n.b2++;
}

void u24_addi(u24 *n, int v) {
  int lo = v & 0xff;
  n.b0 += lo;
  if (n.b0 < lo) n.b1++;
  v = v >> 8;
  if (v != 0) {
    n.b1 += v & 0xff;
    if (n.b1 < (v & 0xff)) n.b2++;
  }
}

void print_u24(u24 *num) {
  char[12] buf;
  byte idx = 11;
  buf[idx] = '\0';

  u24 n = *num;
  while (n.b0 != 0 || n.b1 != 0 || n.b2 != 0) {
    int rem = 0;
    int temp;

    temp = (rem << 8) | n.b2;
    n.b2 = temp / 10;
    rem = temp % 10;

    temp = (rem << 8) | n.b1;
    n.b1 = temp / 10;
    rem = temp % 10;

    temp = (rem << 8) | n.b0;
    n.b0 = temp / 10;
    rem = temp % 10;

    buf[--idx] = '0' + rem;
  }
  if (idx == 11) {
    buf[--idx] = '0';
  }
  puts(&buf[idx]);
}

char*[MAX_ARGS] argv;
byte argc = parse_cmdline(args, argv, MAX_ARGS);

if (argc < 2) {
  showhelp();
  return 0;
}

char *pattern = argv[0];
char *filespec = argv[1];

puts(pattern);putc('\r');

byte mmu6 = mmualloc();
byte old_mmu6 = readreg(0x56);
nextreg(0x56, mmu6);

byte hfile = 0;
byte hdir = 0;

void onerror() {
  if (hfile) fclose(hfile);
  if (hdir) fclose(hdir);
  exit(0);
}
seterrh(onerror);

PFN_EXIT old_exitfn = 0;

void cleanup() {
  mmufree(mmu6);
  nextreg(0x56, old_mmu6);

  if (old_exitfn) {
    old_exitfn();
  }
}
old_exitfn = atexit(cleanup);

DIRENTLFN dirent;
hdir = fopendir(
  ".", 
  filespec,
  DIR_LFN | DIR_WILDCARD | DIR_EN_SF,
  F_EX_DIRS | F_EX_DOTS | F_EX_SYS);

if (!hdir) {
  return errno;
}

while(freaddir(hdir, filespec, &dirent)) {
    char *filename = dirent.name;
    scan_text(filename, pattern);
}

fclose(hdir);
return 0;

bank(1) {
  /* Static Work Buffers */
  char* raw;
  char* mapped;
  
  int pat_len;
  int buf_len;
  int eof;
  int nread;
  int line_start;
  int pos;
  int remain;
  int to_read;
  char saved_char;
  char scan_char;
  u24 loc;
  
  void read_window() {
    if (buf_len < HALF_LINE) {
      to_read = HALF_LINE - buf_len;
      nread = fread(hfile, &raw[buf_len], to_read);
      if (nread <= 0) {
        eof = 1;
      } else {
        buf_len += nread;
      }
    }
  }

  void emit_match(char* filename, char* line) __znccall(1) {
    puts(filename);
    putc('(');
    print_u24(&loc);
    putc(')');
    putc(':');
    puts(line);
    putc('\r');
  }

  byte scan_text(char* filename, char* pattern) {
    pat_len = strlen(pattern);
    buf_len = 0;
    eof = 0;
    raw = LINE_BUF;
    mapped = LINE_BUF + HALF_LINE;
    
    loc = {0,0,0};
    u24_inc(&loc);

    hfile = fopen(filename, M_READ);
    if (hfile == 0 || errno != 0) {
      puts("Error: Could not open file\r");
      return 0;
    }

    line_start = 0;
    while (!eof) {
      read_window();

      pos = 0;
      while (pos < buf_len) {
        scan_char = raw[pos];
        if (scan_char == '\n') {
          saved_char = raw[pos];
          raw[pos] = '\0';
          if (match(pattern, &raw[line_start])) emit_match(filename, &raw[line_start]);
          raw[pos] = saved_char;
          pos++;
          line_start = pos;
          u24_inc(&loc);
          continue;
        }

        if (scan_char == '\r') {
          if (pos + 1 >= buf_len && !eof) break;

          saved_char = raw[pos];
          raw[pos] = '\0';
          if (match(pattern, &raw[line_start])) emit_match(filename, &raw[line_start]);
          raw[pos] = saved_char;

          if (pos + 1 < buf_len && raw[pos + 1] == '\n') {
            pos += 2;
          } else {
            pos++;
          }
          line_start = pos;
          u24_inc(&loc);
          continue;
        }

        pos++;
      }

      if (line_start > 0) {
        remain = buf_len - line_start;
        if (remain > 0) memmove(raw, &raw[line_start], remain);
        buf_len = remain;
        line_start = 0;
      } else {
        if (buf_len == HALF_LINE) {
          raw[HALF_LINE - 1] = '\0';
          if (match(pattern, raw)) emit_match(filename, raw);
          buf_len = 0;
          line_start = 0;
        }
      }

      if (eof) break;
    }

    if (buf_len > 0) {
      raw[buf_len] = '\0';
      if (match(pattern, raw)) emit_match(filename, raw);
    }

    fclose(hfile);
    return 1;
  }

  void showhelp() {
    puts("Usage: grep <pattern> <filename>\r");
    puts("Supported Regex:\r");
    puts(" .  - any character\r");
    puts(" ^  - start of line\r");
    puts(" $  - end of line\r");
    puts(" *  - zero or more\r");
    puts(" +  - one or more\r");
    puts(" ?  - zero or one\r");
    puts(" |  - logical OR\r");
    puts(" [...] - character class\r");
    puts(" [^...] - inverted class\r");
    puts(" a-z - character range\r");
    puts(" \\d - digit\r");
    puts(" \\w - word character\r");
    puts(" \\s - whitespace character\r");
    puts(" (?i) - case insensitivity ON\r");
    puts(" (?-i) - case insensitivity OFF\r");
  }
}
